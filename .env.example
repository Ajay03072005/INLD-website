# Environment variables for INLD Website
# Copy this file to .env and update with your actual values

# API Configuration
REACT_APP_API_URL=http://localhost:5000
# For production, replace with your actual backend URL:
# REACT_APP_API_URL=https://api.inld.org

# Other configuration options
REACT_APP_SITE_NAME="Indian National Lok Dal"
REACT_APP_CONTACT_EMAIL="info@inld.org"
REACT_APP_PHONE="+91-1234567890"

# Google Analytics (if needed)
# REACT_APP_GA_TRACKING_ID=GA_MEASUREMENT_ID

# Social Media Links
REACT_APP_FACEBOOK_URL="https://facebook.com/inld"
REACT_APP_TWITTER_URL="https://twitter.com/inld"
REACT_APP_INSTAGRAM_URL="https://instagram.com/inld"
REACT_APP_YOUTUBE_URL="https://youtube.com/inld"
